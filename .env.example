# =========================
# APP
# =========================
APP_INSTANCE_NAME=fastapi_template
DEBUG=true
SERVER_HOST=http://localhost:8000
FRONTEND_URL=http://localhost:3000

SECRET_KEY=super-secret-key

# =========================
# DATABASE
# =========================
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/testdb
SQL_ECHO=false

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_PRE_PING=true

# =========================
# REDIS / CELERY
# =========================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

CELERY_TASK_TIME_LIMIT=300
CELERY_RESULT_EXPIRES=3600
CELERY_QUEUE_DEFAULT=default
CELERY_TASK_ALWAYS_EAGER=true

# =========================
# AUTH / SECURITY
# =========================
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_SPECIAL=true
PASSWORD_REQUIRE_DIGIT=true

PASSWORD_PEPPER=dev-global-pepper-change-me
PASETO_SECRET_KEY=another-super-secret-key
HASHIDS_SALT=dev-hashids-salt
HASHIDS_MIN_LENGTH=8

ACCESS_TOKEN_COOKIE_NAME=access_token
REFRESH_TOKEN_COOKIE_NAME=refresh_token
SECURE_COOKIES=false
COOKIE_SAMESITE=lax

RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_SIGNUP=2/minute
RATE_LIMIT_PASSWORD_RESET=3/minute
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION_MINUTES=15

REQUIRE_EMAIL_VERIFICATION=False

# =========================
# EMAIL (DEV MODE = LOGGING RECOMMENDED)
# =========================
EMAIL_SERVICE_ENABLED=true
EMAIL_ENABLED=true
EMAIL_PROVIDER=smtp

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
EMAIL_FROM_ADDRESS=your_email@gmail.com

# =========================
# STORAGE
# =========================
STORAGE_BACKEND=local
MEDIA_DIR=media
MEDIA_URL=/media
MEDIA_BASE_URL=http://localhost:8000/media
MAX_AVATAR_SIZE_MB=5

S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT_URL=
S3_USE_PATH_STYLE=false

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# =========================
# RATE LIMIT / API
# =========================
API_KEY=dev-api-key-change-me

# =========================
# CELERY DEV BEHAVIOR
# =========================
CELERY_TASK_ALWAYS_EAGER=true