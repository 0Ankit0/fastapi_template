# =========================
# APP
# =========================
APP_INSTANCE_NAME=fastapi_template
DEBUG=true
SERVER_HOST=http://localhost:8000
FRONTEND_URL=http://localhost:3000

SECRET_KEY=super-secret-key

# =========================
# DATABASE
# =========================
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/testdb
SQL_ECHO=false

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_PRE_PING=true

# =========================
# REDIS / CELERY
# =========================
REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# CELERY_TASK_TIME_LIMIT=300
# CELERY_RESULT_EXPIRES=3600
# CELERY_QUEUE_DEFAULT=default
# CELERY_TASK_ALWAYS_EAGER=true

# --- RabbitMQ Configuration ---
# Format: amqp://user:password@container_name:port//
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//

# Using RabbitMQ's built-in RPC backend for task results
CELERY_RESULT_BACKEND=rpc://

CELERY_TASK_TIME_LIMIT=300
CELERY_RESULT_EXPIRES=3600
CELERY_QUEUE_DEFAULT=celery

# CRITICAL: Change to false so tasks actually go to RabbitMQ 
# instead of running synchronously inside the FastAPI process.
CELERY_TASK_ALWAYS_EAGER=false

# =========================
# AUTH / SECURITY
# =========================
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_SPECIAL=true
PASSWORD_REQUIRE_DIGIT=true

PASSWORD_PEPPER=dev-global-pepper-change-me
PASETO_SECRET_KEY=another-super-secret-key
HASHIDS_SALT=dev-hashids-salt
HASHIDS_MIN_LENGTH=8

ACCESS_TOKEN_COOKIE_NAME=access_token
REFRESH_TOKEN_COOKIE_NAME=refresh_token
SECURE_COOKIES=false
COOKIE_SAMESITE=lax

RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_SIGNUP=2/minute
RATE_LIMIT_PASSWORD_RESET=3/minute
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION_MINUTES=15

REQUIRE_EMAIL_VERIFICATION=False

# =========================
# EMAIL (DEV MODE = LOGGING RECOMMENDED)
# =========================
EMAIL_SERVICE_ENABLED=false
EMAIL_ENABLED=false
EMAIL_PROVIDER=smtp

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
EMAIL_FROM_ADDRESS=your_email@gmail.com

# =========================
# Push Notifications (DEV MODE = LOGGING RECOMMENDED)
# =========================
PUSH_SERVICE_ENABLED=false
PUSH_ENABLED=false
PUSH_PROVIDER=onesignal
FCM_SERVER_KEY=your_fcm_server_key
FCM_PROJECT_ID=your_fcm_project_id
FCM_SERVICE_ACCOUNT_JSON=your_fcm_service_account_json_path
FCM_SERVICE_ACCOUNT_FILE=your_fcm_service_account_file_path
FCM_WEB_VAPID_KEY=your_fcm_web_vapid_key
FCM_STORAGE_BUCKET=your_fcm_storage_bucket
FCM_API_KEY=your_fcm_api_key
FCM_APP_ID=your_fcm_app_id
FCM_MESSAGING_SENDER_ID=your_fcm_messaging_sender_id
FCM_AUTH_DOMAIN=your_fcm_auth_domain
FCM_MEASUREMENT_ID=your_fcm_measurement_id

ONESIGNAL_APP_ID=your_onesignal_app_id
ONESIGNAL_API_KEY=your_onesignal_api_key

# =========================
# STORAGE
# =========================
STORAGE_BACKEND=local
MEDIA_DIR=media
MEDIA_URL=/media
MEDIA_BASE_URL=${SERVER_HOST}/media
MAX_AVATAR_SIZE_MB=5

S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT_URL=
S3_USE_PATH_STYLE=false

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# =========================
# RATE LIMIT / API
# =========================
API_KEY=dev-api-key-change-me

# =========================
# OTEL / TRACING
# =========================
OTEL_SERVICE_NAME=fastapi-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
COLLECTOR_OTLP_ENABLED=true

# =========================
# HTTP CLIENT
# =========================
HTTP_TIMEOUT_SECONDS=10
HTTP_RETRY_COUNT=3
HTTP_BACKOFF_SECONDS=1