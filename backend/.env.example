PYTHONPATH=.
# -----------------------------------------------------------------------------
# Core settings
# -----------------------------------------------------------------------------
PROJECT_NAME=FastAPI Template
API_V1_STR=/api/v1
SECRET_KEY=test_secret_key
# Optional pepper added to password hashing (recommended to keep this secret and stable across deployments)
PASSWORD_PEPPER=test_secret_key
ACCESS_TOKEN_EXPIRE_MINUTES=11520
REFRESH_TOKEN_EXPIRE_DAYS=7
ACCESS_TOKEN_COOKIE=access_token
REFRESH_TOKEN_COOKIE=refresh_token
SECURE_COOKIES=False

# Account security
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION_MINUTES=30
REQUIRE_EMAIL_VERIFICATION=False
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=True
PASSWORD_REQUIRE_LOWERCASE=True
PASSWORD_REQUIRE_DIGIT=True
PASSWORD_REQUIRE_SPECIAL=False

# Debug / runtime
DEBUG=True
TESTING=False

# -----------------------------------------------------------------------------
# Template feature toggles
# -----------------------------------------------------------------------------
FEATURE_AUTH=True
FEATURE_MULTITENANCY=True
FEATURE_NOTIFICATIONS=True
FEATURE_WEBSOCKETS=True
FEATURE_FINANCE=True
FEATURE_ANALYTICS=True
FEATURE_SOCIAL_AUTH=True

# CORS
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:3000

# -----------------------------------------------------------------------------
# Database settings
# -----------------------------------------------------------------------------
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app
# By default the app uses SQLite in DEBUG mode; override to use Postgres
DATABASE_URL=sqlite+aiosqlite:///./app.db
SYNC_DATABASE_URL=sqlite:///./app.db

# -----------------------------------------------------------------------------
# Redis / Celery settings
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=10
# Optional overrides:
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# -----------------------------------------------------------------------------
