COMPOSE_PROJECT_NAME=fastapi-template
DOCKER_IMAGE_TAG=prod

PROJECT_NAME=FastAPI Template
POSTGRES_DB=template
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_PORT=5432
REDIS_PORT=6379
BACKEND_PORT=8000
FRONTEND_PORT=3000

BACKEND_DEBUG=False
BACKEND_APP_ENV=production
BACKEND_SECRET_KEY=replace-with-a-long-random-secret
BACKEND_PASSWORD_PEPPER=replace-with-a-stable-secret-pepper
BACKEND_SECURE_COOKIES=True
BACKEND_COOKIE_SAMESITE=none
CELERY_TASK_ALWAYS_EAGER=False

FEATURE_AUTH=True
FEATURE_MULTITENANCY=True
FEATURE_NOTIFICATIONS=True
FEATURE_WEBSOCKETS=True
FEATURE_FINANCE=True
FEATURE_ANALYTICS=False
FEATURE_SOCIAL_AUTH=False
FEATURE_MAPS=False

BACKEND_CORS_ORIGINS=https://app.example.com
TRUSTED_HOSTS=app.example.com,api.example.com
SERVER_HOST=https://api.example.com
FRONTEND_URL=https://app.example.com
WS_ALLOWED_ORIGINS=https://app.example.com
SOCIAL_AUTH_REDIRECT_URL=https://app.example.com/auth/callback

FRONTEND_NODE_ENV=production
NEXT_PUBLIC_APP_NAME=FastAPI Template
NEXT_PUBLIC_API_URL=https://api.example.com/api/v1
NEXT_PUBLIC_WS_URL=wss://api.example.com
NEXT_PUBLIC_ANALYTICS_ENABLED=false
NEXT_PUBLIC_ANALYTICS_PROVIDER=posthog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
INTERNAL_API_BASE_URL=http://backend:8000
