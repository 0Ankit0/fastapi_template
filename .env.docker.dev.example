COMPOSE_PROJECT_NAME=fastapi-template-dev
DOCKER_IMAGE_TAG=dev

PROJECT_NAME=FastAPI Template (Dev)
POSTGRES_DB=template
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
REDIS_PORT=6379
BACKEND_PORT=8000
FRONTEND_PORT=3000

BACKEND_DEBUG=True
BACKEND_APP_ENV=development
BACKEND_SECRET_KEY=change-me-dev-only
BACKEND_PASSWORD_PEPPER=change-me-dev-only
BACKEND_SECURE_COOKIES=False
BACKEND_COOKIE_SAMESITE=lax
CELERY_TASK_ALWAYS_EAGER=False

FEATURE_AUTH=True
FEATURE_MULTITENANCY=True
FEATURE_NOTIFICATIONS=True
FEATURE_WEBSOCKETS=True
FEATURE_FINANCE=True
FEATURE_ANALYTICS=False
FEATURE_SOCIAL_AUTH=False
FEATURE_MAPS=False

BACKEND_CORS_ORIGINS=http://localhost:3000
TRUSTED_HOSTS=localhost,127.0.0.1
SERVER_HOST=http://localhost:8000
FRONTEND_URL=http://localhost:3000
WS_ALLOWED_ORIGINS=http://localhost:3000
SOCIAL_AUTH_REDIRECT_URL=http://localhost:3000/auth/callback

FRONTEND_NODE_ENV=development
NEXT_PUBLIC_APP_NAME=FastAPI Template
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_ANALYTICS_ENABLED=false
NEXT_PUBLIC_ANALYTICS_PROVIDER=posthog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
INTERNAL_API_BASE_URL=http://backend:8000
